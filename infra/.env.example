# Copy this to .env (do not commit .env). Defaults already match the existing GCP project.
PROJECT=x-object-492801-h3
ZONE=us-south1-a
TPU_NAME=mlsystems-vllm
ACCELERATOR_TYPE=v5litepod-4
RUNTIME_VERSION=v2-alpha-tpuv5-lite

# vLLM serving
MODEL=NousResearch/Meta-Llama-3.1-8B-Instruct
VLLM_PORT=8000
MAX_MODEL_LEN=8192
TENSOR_PARALLEL_SIZE=4

# Optional: only needed if you switch to a gated model (e.g. Llama)
HF_TOKEN=
